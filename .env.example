# =============================================================================
# mybot 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入你的实际值:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# 工作空间（会话、记忆、调试文件的存储目录）
# ---------------------------------------------------------------------------
WORKSPACE=~/.mybot/workspace

# ---------------------------------------------------------------------------
# LLM 提供商
# ---------------------------------------------------------------------------
PROVIDER_NAME="openrouter"

# 模型名称
LLM_MODEL_ID="deepseek/deepseek-v4-flash"
LIGHT_MODEL_NAME="deepseek/deepseek-v4-flash"

# API 密钥（必填 — 没有密钥无法调用 LLM）
OPENAI_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# API 地址
OPENAI_API_BASE="https://openrouter.ai/api/v1"

# 请求超时（秒），默认 60
LLM_TIMEOUT=60

# ---------------------------------------------------------------------------
# HTTP/WebSocket 服务器（mybot-server）
# ---------------------------------------------------------------------------
MYBOT_HOST="127.0.0.1"
MYBOT_PORT="8080"
# MYBOT_API_KEY=""                    # Bearer token 鉴权（不设置则禁用鉴权）

# ---------------------------------------------------------------------------
# Web 搜索（可选 — 不设置则搜索功能不可用）
# ---------------------------------------------------------------------------
# TAVILY_API_KEY="tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# GOOGLE_API_KEY=""
# GOOGLE_CSE_ID=""
# BING_API_KEY=""

# ---------------------------------------------------------------------------
# 调试
# ---------------------------------------------------------------------------
# DUMP_LLM_MESSAGES=1                 # 开启后将完整 LLM 上下文写入 workspace/debug/

# 是否保存检查点
MYBOT_CHECKPOINT=true

# ---------------------------------------------------------------------------
# OpenTelemetry 桥接（可选 — 将 trace 导出到 Jaeger / OTel Collector）
# ---------------------------------------------------------------------------
# MYBOT_OTEL_ENABLED=1                 # 启用 OTel 桥接（需要 pip install mybot[otel]）
# MYBOT_OTEL_ENDPOINT="http://localhost:4318/v1/traces"  # OTLP HTTP 地址（默认）
# MYBOT_OTEL_SERVICE_NAME="mybot"      # 服务名称（默认 mybot）