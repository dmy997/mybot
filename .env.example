# =============================================================================
# mybot 环境变量配置
# =============================================================================
# 首选方式: 编辑 ~/.mybot/settings.json 的 "env" 字典（首次运行自动生成）
# 传统方式: 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# 优先级: shell 环境变量 > settings.json > .env 文件
# =============================================================================

# ---------------------------------------------------------------------------
# 工作空间（会话、记忆、调试文件的存储目录）
# ---------------------------------------------------------------------------
WORKSPACE=~/.mybot/workspace

# ---------------------------------------------------------------------------
# LLM 提供商
# ---------------------------------------------------------------------------
PROVIDER_NAME="openrouter"

# 模型名称
LLM_MODEL_ID="deepseek/deepseek-v4-flash"
LIGHT_MODEL_NAME="deepseek/deepseek-v4-flash"

# API 密钥（必填 — 没有密钥无法调用 LLM）
OPENAI_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# API 地址
OPENAI_API_BASE="https://openrouter.ai/api/v1"

# 请求超时（秒），默认 60
LLM_TIMEOUT=60

# ---------------------------------------------------------------------------
# 上下文窗口配置
# ---------------------------------------------------------------------------
# 主 LLM 模型的上下文窗口大小（token 数）
# CONTEXT_WINDOW=200000

# 每轮对话为模型输出保留的 token 数
# MAX_OUTPUT_TOKENS=20000

# 阈值缓冲区（以 effective_window 的比例表示，即 CONTEXT_WINDOW - MAX_OUTPUT_TOKENS）
# WARNING_BUFFER_RATIO=0.11      # 触发"上下文接近满载"警告
# AUTOCOMPACT_BUFFER_RATIO=0.072 # 触发自动 LLM 压缩
# BLOCK_BUFFER_RATIO=0.017       # 触发强制阻塞（必须先压缩才能继续）

# 压缩时为最近消息保留的上下文窗口比例
# COMPRESS_RATIO=0.5

# 每轮对话后触发后台摘要的比例
# CONSOLIDATION_RATIO=0.7

# 空闲压缩前的非活动秒数（0 = 禁用）
# IDLE_COMPRESS_SECONDS=300

# 会话消息硬上限（超过此数量时，最旧的消息将被裁剪）
# MAX_SESSION_MESSAGES=2000

# 会话自动过期天数（0 = 禁用过期）
# SESSION_TTL_DAYS=30

# ---------------------------------------------------------------------------
# HTTP/WebSocket 服务器（mybot-server）
# ---------------------------------------------------------------------------
MYBOT_HOST="127.0.0.1"
MYBOT_PORT="8080"
# MYBOT_API_KEY=""                    # Bearer token 鉴权（不设置则禁用鉴权）

# ---------------------------------------------------------------------------
# 混合搜索（SQLite FTS5 + sqlite-vec 向量搜索）
# ---------------------------------------------------------------------------
HYBRID_SEARCH_ENABLED="true"          # 启用混合搜索（false 则仅 FTS5 关键词搜索）
EMBEDDING_MODEL="all-MiniLM-L6-v2"   # sentence-transformers 嵌入模型

# ---------------------------------------------------------------------------
# Web 搜索（可选 — 不设置则搜索功能不可用）
# ---------------------------------------------------------------------------
# TAVILY_API_KEY="tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# GOOGLE_API_KEY=""
# GOOGLE_CSE_ID=""
# BING_API_KEY=""

# ---------------------------------------------------------------------------
# 调试
# ---------------------------------------------------------------------------
# DUMP_LLM_MESSAGES=1                 # 开启后将完整 LLM 上下文写入 workspace/debug/

# 是否保存检查点
MYBOT_CHECKPOINT=true

# ---------------------------------------------------------------------------
# OpenTelemetry 桥接（可选 — 将 trace 导出到 Jaeger / OTel Collector）
# ---------------------------------------------------------------------------
# MYBOT_OTEL_ENABLED=1                 # 启用 OTel 桥接（需要 pip install mybot[otel]）
# MYBOT_OTEL_ENDPOINT="http://localhost:4318/v1/traces"  # OTLP HTTP 地址（默认）
# MYBOT_OTEL_SERVICE_NAME="mybot"      # 服务名称（默认 mybot）